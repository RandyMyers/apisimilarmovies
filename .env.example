## similarmovies/server environment variables
## Copy to .env and fill values.

# Server port
PORT=5000

# MongoDB connection string (required for votes, reviews, suggestions, catalog, curation persistence)
MONGO_URL=mongodb://127.0.0.1:27017/similarmovies

# JWT secret (reserved for future auth; not required for current MVP endpoints)
JWT_SECRET=replace-me

# TMDB API key (required for /api/v1/search and TMDB enrichment)
TMDB_API_KEY=replace-me

# Optional email settings (reserved for future forgot-password)
HOST=
HPORT=
SECURE=
USER=
PASSWORD=

# Optional Cloudinary settings (reserved for future media uploads)
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET=

# Comma-separated browser origins allowed by CORS (in addition to defaults in app.js, including fliqmatch.com).
# CORS_ALLOWED_ORIGINS=https://staging.example.com

# Admin API (protects /api/v1/admin/* and SEO admin write routes)
# In development, if ADMIN_API_TOKEN is empty, admin routes are allowed without a token.
# In production (NODE_ENV=production), ADMIN_API_TOKEN must be set or requests return 503.
ADMIN_API_TOKEN=
# Optional: force open admin in any environment (only on trusted networks)
# ADMIN_AUTH_MODE=optional
# ADMIN_DEFAULT_ROLE=editor

# Ad analytics: periodic rollup of AdEvent → AdDailyAnalytics (single worker should set this to avoid duplicate work).
# AD_ROLLUP_SCHEDULER=1

# Ad events (optional compliance): TTL auto-deletes raw events after N days (MongoDB TTL index on createdAt).
# AD_EVENT_RETENTION_DAYS=365

# Store hashed IP instead of raw when AD_EVENT_HASH_IP=1 (set a long random AD_EVENT_IP_SALT in production).
# AD_EVENT_HASH_IP=0
# AD_EVENT_IP_SALT=

# Log verbose ad placement resolution (site key, targeting checks per campaign). Disable in production unless debugging.
# DEBUG_ADS=1

